# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Backend Configuration (Service Role - NEVER use in frontend)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# N8N Webhook Dinâmico
VITE_N8N_WEBHOOK_DINAMICO=https://vieiraaguiaradvogados.app.n8n.cloud/webhook/agente-juridico-dinamico

# N8N Webhook — processamento de holerites (lote até 12 PDFs)
# VITE_N8N_WEBHOOK_HOLERITE=https://n8n-lab-n8n.bjivvx.easypanel.host/webhook/processar-holerite

# DataJud (API Pública do CNJ) — Edge Function datajud-search
# Chave pública fornecida pelo CNJ (header: "Authorization: APIKey <chave>")
# Valor vigente em docs/api-datajud-cnj/API_DataJud_Acessos.md
DATAJUD_API_KEY=your_datajud_public_api_key
# Opcional — sobrescreve a URL base (default abaixo)
# DATAJUD_BASE_URL=https://api-publica.datajud.cnj.jus.br

# Agente processual (OpenAI) — Edge Function datajud-process-agent
OPENAI_API_KEY=your_openai_api_key
